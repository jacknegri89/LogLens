# Copy this file to `.env` and fill in the values.
# `.env` is git-ignored — never commit real secrets.

# ── Server ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (Prisma) ───────────────────────────────────
# SQLite for local dev. For production, switch the provider in
# prisma/schema.prisma to "postgresql" and use a postgresql:// URL.
DATABASE_URL="file:./dev.db"

# ── AI provider ─────────────────────────────────────────
# Which engine analyzes the logs: "openai" or "ollama".
AI_PROVIDER=openai

# OpenAI — used when AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Ollama — used when AI_PROVIDER=ollama (local, free, no API key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Client ──────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
