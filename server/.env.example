# Copy this file to `.env` and adjust the values. `.env` is git-ignored.

PORT=3001
NODE_ENV=development

# SQLite for local dev — zero setup. The database file is created when you run
# `npm run prisma:migrate`.
#
# To move to PostgreSQL/Supabase later: change the provider in
# prisma/schema.prisma to "postgresql" and paste your connection string here.
DATABASE_URL="file:./dev.db"

# Which AI engine analyzes the logs:
#   mock   -> no setup, returns a plausible canned report (great for a first run)
#   openai -> uses the OpenAI API (needs OPENAI_API_KEY)
#   ollama -> uses a local Ollama model (free, offline)
AI_PROVIDER=mock

# Ollama (local, free) — used when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI — used when AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
