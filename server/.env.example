# Copy this file to `.env` and fill in the values. `.env` is git-ignored.

PORT=3001
NODE_ENV=development

# PostgreSQL connection string.
# Local dev: create a free Supabase project at supabase.com, then paste the
# "URI" from Settings → Database → Connection string here.
# Production (Render): set this in the Render dashboard → Environment.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Which AI engine analyzes the logs:
#   mock   -> no setup, returns a plausible canned report (great for first run)
#   openai -> uses the OpenAI API (needs OPENAI_API_KEY)
#   ollama -> uses a local Ollama model (free, offline)
AI_PROVIDER=mock

# Ollama (local, free) — used when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI — used when AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
