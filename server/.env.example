# Copy this file to `.env` and fill in the values. `.env` is git-ignored.

PORT=3001
NODE_ENV=development

# Supabase PostgreSQL — get these from supabase.com → Connect → ORM → Prisma
# Replace [YOUR-PASSWORD] with your database password.

# Transaction-mode pooler (used by the app at runtime)
DATABASE_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session-mode pooler (used by Prisma migrate — bypasses pgbouncer)
DIRECT_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# Which AI engine analyzes the logs:
#   mock   -> no setup, returns a plausible canned report (great for first run)
#   openai -> uses the OpenAI API (needs OPENAI_API_KEY)
#   ollama -> uses a local Ollama model (free, offline)
AI_PROVIDER=mock

# Ollama (local, free) — used when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI — used when AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
